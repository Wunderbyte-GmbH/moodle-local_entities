{{!
    @template local_entities/view/parts/switcher
    On-page template switcher for managers: preview links + an explicit "save" action.
    Context: { entityid, baseurl, ispreview, savekey, templates: [{key,name,icon,active,url}] }

    Example context (json):
    {
        "entityid": 1,
        "baseurl": "https://example.com/view",
        "entitytype": "location",
        "templates": [
            {
                "url": "https://example.com/view?t=classic",
                "active": true,
                "icon": "fa-th-large",
                "name": "Classic"
            },
            {
                "url": "https://example.com/view?t=compact",
                "active": false,
                "icon": "fa-list",
                "name": "Compact"
            }
        ],
        "ispreview": true,
        "savekey": "classic",
        "savelabel": "Save as default"
    }
}}
<div class="local-entities-viewswitcher card shadow-sm mb-3"
     data-entityid="{{entityid}}" data-baseurl="{{baseurl}}" data-entitytype="{{entitytype}}">
    <div class="card-body py-2 d-flex flex-wrap align-items-center gap-2">
        <span class="me-2 text-muted"><i class="fa fa-eye"></i> {{#str}}viewtemplate, local_entities{{/str}}</span>
        <div class="btn-group btn-group-sm" role="group" aria-label="{{#str}}viewtemplate, local_entities{{/str}}">
            {{#templates}}
                <a href="{{url}}"
                   class="btn {{#active}}btn-primary{{/active}}{{^active}}btn-outline-secondary{{/active}}">
                    <i class="fa fa-fw {{icon}}"></i> {{name}}
                </a>
            {{/templates}}
        </div>
        {{#ispreview}}
            <span class="badge bg-warning text-dark ms-2">{{#str}}viewtemplatepreview, local_entities{{/str}}</span>
            <button type="button" class="btn btn-sm btn-success ms-auto"
                    data-action="save-view-template" data-template="{{savekey}}" data-entitytype="{{entitytype}}">
                <i class="fa fa-save"></i> {{savelabel}}
            </button>
            <a href="{{baseurl}}" class="btn btn-sm btn-link">{{#str}}cancel{{/str}}</a>
        {{/ispreview}}
    </div>
</div>
