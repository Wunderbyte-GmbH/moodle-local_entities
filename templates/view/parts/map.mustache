{{!
    @template local_entities/view/parts/map
    Shared map block. Renders, in order of preference: a manually pasted embed, an OpenStreetMap
    embed geocoded from the address, or a plain "open map" link. Expects the entity context with
    {{#mapdata}} (embedhtml | osmembedurl + osmlink | maplink).
}}
{{#mapdata}}
    {{#embedhtml}}
        <div class="mapcontainer entities">{{{embedhtml}}}</div>
    {{/embedhtml}}
    {{#osmembedurl}}
        <iframe title="OpenStreetMap" class="w-100 border rounded" style="min-height: 60vh;"
                src="{{osmembedurl}}" loading="lazy"></iframe>
        {{#osmlink}}
            <div class="mt-2">
                <a href="{{osmlink}}" class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener">
                    <i class="fa fa-external-link"></i> {{#str}}openmap, local_entities{{/str}}</a>
            </div>
        {{/osmlink}}
    {{/osmembedurl}}
    {{^embedhtml}}
        {{^osmembedurl}}
            {{#maplink}}
                <a href="{{maplink}}" class="btn btn-outline-primary" target="_blank" rel="noopener">
                    <i class="fa fa-map-marker"></i> {{#str}}openmap, local_entities{{/str}}</a>
            {{/maplink}}
        {{/osmembedurl}}
    {{/embedhtml}}
{{/mapdata}}
