{{!
    @template local_entities/view/image
    Image-focused detail view: large picture/PDF in the centre (replaces the calendar).
    Reproduces the previous "show picture instead of calendar" layout.

    Example context (json):
    {
        "name": "Room A.101",
        "haspicture": true,
        "picture": "https://placehold.co/600x400",
        "haspdf": false,
        "hasleftsidebar": false,
        "hasrightsidebar": false
    }
}}
<div class="container-fluid shadow-bottom pb-3" data-viewtemplate="image">
    <div class="row">
        <div class="col-md-12">
            {{> local_entities/view/parts/title }}
        </div>
    </div>
</div>
<div class="row pt-3" style="background-color:#eee;">
    {{> local_entities/view/parts/sidebar_left }}
    <div class="col-xl-6 col-lg-12 flex-fill mb-3" data-area="center">
        <div class="card shadow mb-3">
            <div class="card-body">
                <div class="w-100 m-auto">
                {{#haspicture}}
                    <img class="img-fluid w-100" src="{{picture}}">
                {{/haspicture}}
                {{#haspdf}}
                    <iframe class="img-fluid w-100" style="min-height: 70vh;" src="{{picture}}"></iframe>
                {{/haspdf}}
                </div>
            </div>
        </div>
    </div>
    {{> local_entities/view/parts/sidebar_right }}
</div>
