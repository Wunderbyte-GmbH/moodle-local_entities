{{!
    @template local_entities/view/classic
    Classic three-column detail view: image thumbnail + title, sidebars (metadata/affiliation and
    contacts/address) and a centre block linking to the full calendar. This is the baseline layout.

    Example context (json):
    {
        "name": "Room A.101",
        "haspicture": true,
        "picture": "https://placehold.co/200x200",
        "haspdf": false,
        "calendarurl": "https://example.com/calendar",
        "hasleftsidebar": false,
        "hasrightsidebar": false
    }
}}
<div class="container-fluid shadow-bottom pb-3" data-viewtemplate="classic">
    <div class="row">
        <div class="col-md-2">
            {{#haspicture}}
                <img class="img-fluid img-thumbnail" src="{{picture}}">
            {{/haspicture}}
            {{#haspdf}}
                <iframe class="img-fluid img-thumbnail" src="{{picture}}"></iframe>
            {{/haspdf}}
        </div>
        <div class="col-md-10">
            {{> local_entities/view/parts/title }}
        </div>
    </div>
</div>
<div class="row pt-3" style="background-color:#eee;">
    {{> local_entities/view/parts/sidebar_left }}
    <div class="col-xl-6 col-lg-12 flex-fill mb-3" data-area="center">
        <div class="card shadow mb-3">
            <div class="card-body">
                <div>
                    <h2 class="d-inline-block me-3 mb-4">{{#str}}calendar , local_entities{{/str}} </h2>
                    <a href="{{calendarurl}}" class="btn btn-outline-info btn-block" target="_blank"><i
                            class="fa fa-external-link"></i> {{#str}}opencalendar , local_entities{{/str}}</a>
                </div>
            </div>
        </div>
    </div>
    {{> local_entities/view/parts/sidebar_right }}
</div>
